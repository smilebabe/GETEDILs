-- Enable RLS on governance_states
ALTER TABLE governance_states ENABLE ROW LEVEL SECURITY;

-- Policy: Users can only see their own governance states
CREATE POLICY "Users can view their own governance states"
ON governance_states
FOR SELECT
USING (auth.uid() = user_id);

-- Policy: Users can only insert governance states for themselves
CREATE POLICY "Users can insert their own governance states"
ON governance_states
FOR INSERT
WITH CHECK (auth.uid() = user_id);

-- Policy: Users can only update their own governance states
CREATE POLICY "Users can update their own governance states"
ON governance_states
FOR UPDATE
USING (auth.uid() = user_id)
WITH CHECK (auth.uid() = user_id);

-- Enable RLS on tutor_lessons
ALTER TABLE tutor_lessons ENABLE ROW LEVEL SECURITY;

-- Policy: Any authenticated user can read lessons
CREATE POLICY "Authenticated users can read tutor lessons"
ON tutor_lessons
FOR SELECT
USING (auth.role() = 'authenticated');

-- Enable RLS on governance_pillars
ALTER TABLE governance_pillars ENABLE ROW LEVEL SECURITY;

-- Policy: Authenticated users can read governance pillars
CREATE POLICY "Authenticated users can read governance pillars"
ON governance_pillars
FOR SELECT
USING (auth.role() = 'authenticated');
